
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn();
    }

    function isAppointmentCustomer(data) {
      return isSignedIn() && data.customerId == request.auth.uid;
    }

    function isAppointmentBarber(data) {
      return isSignedIn() && data.barberId == request.auth.uid;
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /customers/{customerId} {
      allow get: if isOwner(customerId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /barbers/{barberId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /schedules/{scheduleId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }

      match /portfolioImages/{imageId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    match /appointments/{appointmentId} {
      allow get: if isAppointmentCustomer(resource.data) || isAppointmentBarber(resource.data) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAppointmentCustomer(resource.data) || isAppointmentBarber(resource.data) || isAdmin();
      allow delete: if isAdmin();
    }

    match /serviceCategories/{serviceCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /deals/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /galleryImages/{imageId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /styleRecommendations/{recommendationId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
