
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow get, list: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /barbers/{barberId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /galleryImages/{imageId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /deals/{dealId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /appointments/{appointmentId} {
      // Allow everyone to create and list. 
      // Listing is required for the booking page to calculate available time slots.
      allow create, list: if true;
      
      // Allow only signed-in administrators to manage or view details of specific appointments.
      allow get, update, delete: if isSignedIn();
    }
  }
}
