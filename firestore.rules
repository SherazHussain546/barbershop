rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Gentlecut Guild Security Rules
     * 
     * Philosophy:
     * This ruleset enforces a multi-tier authorization model:
     * 1. Public Access: Core business data (Services, Categories, Gallery, Barber Profiles) is publicly readable.
     * 2. User/Barber Ownership: Personal profiles, working hours, and portfolios are restricted to the owner.
     * 3. Shared Access: Appointments are accessible only by the assigned customer, the assigned barber, or an administrator.
     * 4. Admin Override: Global administrators have elevated permissions across all collections.
     * 
     * Data Structure:
     * - /users/{userId}: Individual user/customer profiles.
     * - /barbers/{barberId}: Barber professional profiles with nested subcollections for working hours and portfolios.
     * - /appointments/{appointmentId}: Shared transaction records using denormalized IDs for authorization.
     * - /roles_admin/{adminId}: DBAC (Database Access Control) collection to identify system admins.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || (resource != null && isAdmin())) && request.resource.data.id == resource.data.id;
      allow delete: if (resource != null && isAdmin());
    }

    match /barbers/{barberId} {
      allow get, list: if true;
      allow create: if (isOwner(barberId) || isAdmin()) && request.resource.data.id == barberId;
      allow update: if (isExistingOwner(barberId) || (resource != null && isAdmin())) && request.resource.data.id == resource.data.id;
      allow delete: if (resource != null && isAdmin());

      match /workingHours/{workingHoursId} {
        allow get, list: if true;
        allow create: if isOwner(barberId) || isAdmin();
        allow update, delete: if (isExistingOwner(barberId) || (resource != null && isAdmin()));
      }

      match /portfolioImages/{imageId} {
        allow get, list: if true;
        allow create: if isOwner(barberId) || isAdmin();
        allow update, delete: if (isExistingOwner(barberId) || (resource != null && isAdmin()));
      }
    }

    match /appointments/{appointmentId} {
      function isParticipant() {
        return isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.barberId == request.auth.uid);
      }

      allow get, list: if isParticipant() || isAdmin();
      allow create: if isSignedIn() && (request.resource.data.customerId == request.auth.uid || isAdmin());
      allow update: if resource != null && (isParticipant() || isAdmin());
      allow delete: if resource != null && isAdmin();
    }

    match /serviceCategories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /galleryImages/{imageId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /roles_admin/{adminId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /roles/{roleId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}