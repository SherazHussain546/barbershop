
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Gentlecut Guild application.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "profileImageUrl": { "type": "string", "format": "uri" },
        "roleIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "roleIds", "createdAt", "updatedAt"]
    },
    "Service": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Service",
      "type": "object",
      "description": "Defines a specific barber service.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Haircuts", "Grooming", "Packages"] },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "description", "durationMinutes", "price", "category", "createdAt"]
    },
    "Deal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Deal",
      "type": "object",
      "description": "Represents a special offer or promotion.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "discountType": { "type": "string", "enum": ["PERCENTAGE", "FIXED"] },
        "discountValue": { "type": "number" },
        "validUntil": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "discountType", "discountValue", "createdAt"]
    },
    "Subscription": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Subscription",
      "type": "object",
      "description": "Represents a membership or subscription tier.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "billingCycle": { "type": "string", "enum": ["MONTHLY", "YEARLY"] },
        "features": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "billingCycle", "features", "createdAt"]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents a client booking.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "serviceIds": { "type": "array", "items": { "type": "string" } },
        "barberId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "CONFIRMED", "COMPLETED", "CANCELLED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "phone", "serviceIds", "startTime", "endTime", "totalPrice", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/services/{serviceId}",
        "definition": {
          "entityName": "Service",
          "schema": { "$ref": "#/backend/entities/Service" },
          "description": "Stores individual services."
        }
      },
      {
        "path": "/deals/{dealId}",
        "definition": {
          "entityName": "Deal",
          "schema": { "$ref": "#/backend/entities/Deal" },
          "description": "Stores promotional deals."
        }
      },
      {
        "path": "/subscriptions/{subscriptionId}",
        "definition": {
          "entityName": "Subscription",
          "schema": { "$ref": "#/backend/entities/Subscription" },
          "description": "Stores subscription tiers."
        }
      },
      {
        "path": "/galleryImages/{imageId}",
        "definition": {
          "entityName": "GalleryImage",
          "schema": { "$ref": "#/backend/entities/GalleryImage" },
          "description": "Stores gallery images."
        }
      },
      {
        "path": "/barbers/{barberId}",
        "definition": {
          "entityName": "Barber",
          "schema": { "$ref": "#/backend/entities/Barber" },
          "description": "Stores barber profiles."
        }
      },
      {
        "path": "/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": { "$ref": "#/backend/entities/Appointment" },
          "description": "Stores client appointments."
        }
      }
    ]
  }
}
